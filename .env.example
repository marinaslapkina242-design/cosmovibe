# Скопируй этот файл в .env и заполни значения

# PostgreSQL — берёшь из Render (раздел "Connect" твоей БД)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary — берёшь на cloudinary.com в Dashboard
CLOUDINARY_CLOUD_NAME=твой_cloud_name
CLOUDINARY_API_KEY=твой_api_key
CLOUDINARY_API_SECRET=твой_api_secret

# JWT — любая случайная строка (можно сгенерировать)
JWT_SECRET=придумай_длинный_секрет_123456

# Порт (Render сам подставит, не меняй)
PORT=3000
